{
  "registry" : "us-west1-docker.pkg.dev/aggie-experts/pub",

  "repositories" : {
    "project-anduin" : "https://github.com/ucd-library/project-anduin",
    "caskfs" : "https://github.com/ucd-library/caskfs"
  },

  "images" : {
    "harvest" : {
      "contextPath" : ".",
      "options" : {
        "build-arg" : [
          "DAGSTER_IMAGE=${project-anduin.dagster}",
          "CASKFS_IMAGE=${caskfs.caskfs}"
        ]
      }
    },
    "anduin-gateway" : {
      "contextPath" : "./anduin-gateway",
      "options" : {
        "build-arg" : [
          "ANDUIN_AUTH_GATEWAY_IMAGE=${project-anduin.auth-gateway}"
        ]
      }
    },
    "webapp" : {
      "contextPath" : "./webapp"
    },
    "elastic-search" : {
      "contextPath" : "./elastic-search",
      "user" : "elasticsearch"
    },
    "ae-postgres" : {
      "contextPath" : "./postgres",
      "options" : {
        "build-arg" : [
          "POSTGRES_IMAGE=${project-anduin.anduin-pg}"
        ]
      }
    }
  }
}
