{
  "registry" : "us-west1-docker.pkg.dev/aggie-experts/docker",

  "repositories" : {
    "project-anduin" : "https://github.com/ucd-library/project-anduin"
  },

  "images" : {
    "harvest" : {
      "contextPath" : ".",
      "options" : {
        "build-arg" : [
          "DAGSTER_IMAGE=${project-anduin.dagster}"
        ]
      }
    },
    "webapp" : {
      "contextPath" : "./webapp"
    }
  }
}
